{
  "name": "Rafo's Pipeline Tracker (Java 25 LTS)",
  "image": "mcr.microsoft.com/devcontainers/java:25",
  "customizations": {
    "vscode": {
      "settings": {
        "workbench.colorTheme": "Everforest Pro Dark Vibrant"
      },
      "extensions": [
        "vscjava.vscode-java-pack",
        "SonarSource.sonarlint-vscode",
        "qwtel.sqlite-viewer",
        "usernamehw.errorlens",
        "eamodio.gitlens",
        "shengchen.vscode-checkstyle",
        "yzhang.markdown-all-in-one",
        "AndreiLucaci.everforest-pro"
      ]
    }
  },
  "onCreateCommand": "sudo apt-get update && sudo apt-get install -y sqlite3 curl && curl -fsSL https://deb.nodesource.com/setup_22.x | sudo -E bash - && sudo apt-get install -y nodejs",
  "postCreateCommand": "mvn clean install"
}